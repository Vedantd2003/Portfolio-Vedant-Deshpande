# ─── Email (Nodemailer via Gmail) ─────────────────────────────
# Gmail address used to SEND emails
EMAIL_USER=your-gmail@gmail.com

# Gmail App Password (NOT your regular password)
# Generate at: https://myaccount.google.com/apppasswords
# Steps: Google Account → Security → 2-Step Verification → App passwords
EMAIL_PASS=your-16-character-app-password

# Email address to RECEIVE contact form submissions (your inbox)
EMAIL_TO=vdeshpande674@gmail.com

# ─── OpenRouter AI (for AI Chat feature) ──────────────────────
# Get your key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-api-key

# ─── Site URL (used in OpenRouter headers) ────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000
